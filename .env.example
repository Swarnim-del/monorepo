# Reference for all environment variables.
#
# Development: use committed `.env.development` (loaded automatically when DJANGO_ENV is not production).
# Production: copy `.env.production` from the template in-repo (gitignored once edited) or set vars
#   in the process environment. You can also set DJANGO_DOTENV_FILE=/path/to/.env.production.
#
# development | production
DJANGO_ENV=development

# Required in production. Optional in development (built-in dev default exists).
# DJANGO_SECRET_KEY=

# true | false (must be false when DJANGO_ENV=production)
DJANGO_DEBUG=true

# Comma-separated hostnames (no spaces). Required non-empty in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins for CSRF over HTTPS, e.g. https://app.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=

# Optional: load this file instead of default .env.development / .env.production
# DJANGO_DOTENV_FILE=

# In production, HTTPS cookie flags are enabled. If TLS is terminated before Django,
# set DJANGO_SECURE_SSL_REDIRECT=false and configure SECURE_PROXY_SSL_HEADER separately.
# DJANGO_SECURE_SSL_REDIRECT=true

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=monorepo
POSTGRES_USER=monorepo
POSTGRES_PASSWORD=monorepo

# Redis (sessions: REDIS_SESSIONS_DB; Channels: REDIS_CHANNELS_DB)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_SESSIONS_DB=1
REDIS_CHANNELS_DB=0
